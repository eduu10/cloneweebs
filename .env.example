# ============================
# CloneWeebs IA — Environment
# ============================
# Copy this file to .env and fill in the values.
# All services below have free tiers.

# --- Database (Supabase PostgreSQL) ---
# Go to supabase.com → New Project → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# --- Redis (Upstash) ---
# Go to upstash.com → Create Database → Details → copy the redis:// URL
REDIS_URL=rediss://default:xxxx@xxxx.upstash.io:6379

# --- Storage (Supabase Storage) ---
# Same Supabase project → Settings → API → URL and service_role key
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Auth ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-random-64-char-string

# --- LLM (Groq — free tier) ---
# Go to console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_xxxx
GROQ_MODEL=llama-3.3-70b-versatile

# --- CORS ---
# Frontend URL (Vercel deploy URL or localhost)
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# --- App ---
ENVIRONMENT=production

# ============================
# Frontend (.env.local for Next.js)
# ============================
# NEXT_PUBLIC_API_URL=https://your-api.onrender.com
